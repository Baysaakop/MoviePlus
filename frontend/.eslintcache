",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\item\\ItemDetail.js",[],["314","315"],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\account\\PasswordResetConfirm.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\item\\ItemList.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\item\\ItemCreate.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\item\\ItemUpdate.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\posts\\PostCreate.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\components\\Menu.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\api.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\store\\actions\\auth.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\components\\ImageUpload.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\account\\AccountDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\icons\\SunIcon.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\icons\\MoonIcon.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieCard.js",["316"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\index.js",[],["317","318"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\App.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\reducers\\auth.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\routes.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\utility.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\actions\\actionTypes.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\layout\\Layout.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\PasswordResetConfirm.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Login.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Signup.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Logout.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Profile.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\PasswordReset.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemList.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemDetail.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemCreate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\posts\\PostCreate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\containers\\Home.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\icons\\MoonIcon.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\icons\\SunIcon.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\Menu.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\api.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\actions\\auth.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\AccountDetail.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\ImageUpload.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieCard.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieList.js",["319"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieList.js",["320"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",["321","322","323","324","325"],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\components\\GenreTag.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\account\\Moderator.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieAdd.js",["326"],"import { MinusCircleOutlined, PlusCircleOutlined, PlusOutlined } from '@ant-design/icons';\r\nimport { Typography, Form, Row, Col, Input, InputNumber, Select, Button, Popconfirm, DatePicker, message } from 'antd';\r\nimport React, { useState, useEffect } from 'react';\r\nimport ImageUpload from '../components/ImageUpload';\r\nimport axios from 'axios';\r\nimport api from '../api';\r\nimport { connect } from \"react-redux\";\r\nimport moment from 'moment';\r\n\r\nconst { TextArea } = Input;\r\nconst { Option } = Select;\r\n\r\nfunction MovieAdd (props) {\r\n    const [form] = Form.useForm();    \r\n    const [poster, setPoster] = useState();\r\n    const [landscape, setLandscape] = useState();\r\n    const [ratings, setRatings] = useState(); \r\n    const [genres, setGenres] = useState(); \r\n    const [occupations, setOccupations] = useState(); \r\n    const [artists, setArtists] = useState(); \r\n\r\n    useEffect(() => {\r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.ratings\r\n        })\r\n        .then(res => {                        \r\n            setRatings(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.genres\r\n        })\r\n        .then(res => {                        \r\n            setGenres(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.occupations\r\n        })\r\n        .then(res => {                        \r\n            setOccupations(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        form.setFieldsValue({\r\n            crew: [''],\r\n            cast: ['']\r\n        })\r\n    }, [])\r\n\r\n    function onArtistSearch(value) {                \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.artists + \"?name=\" + value\r\n        })\r\n        .then(res => {                        \r\n            setArtists(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        })      \r\n    }\r\n\r\n    function onFinish (values) {      \r\n        console.log(values)            \r\n        const data = {\r\n            name: values.name,\r\n            token: props.token\r\n        }\r\n        if (values.description && values.description !== null) {\r\n            data['description'] = values.description;\r\n        }\r\n        if (values.plot && values.plot !== null) {\r\n            data['plot'] = values.plot;\r\n        }\r\n        if (values.releasedate && values.releasedate !== null) {            \r\n            data['releasedate'] = moment(values.releasedate).format(\"YYYY-MM-DD\");\r\n        }\r\n        if (values.duration && values.duration !== null) {            \r\n            data['duration'] = values.duration;\r\n        }\r\n        if (values.rating && values.rating !== null) {            \r\n            data['rating'] = values.rating;\r\n        }\r\n        if (values.genre && values.genre !== null && values.genre.length > 0 && values.genre[0] !== \"\") {\r\n            data['genre'] = values.genre;\r\n        }\r\n        if (values.crew && values.crew !== null && values.crew.length > 0 && values.crew[0] !== \"\") {\r\n            data['crew'] = values.crew;\r\n        }\r\n        if (values.cast && values.cast !== null && values.cast.length > 0 && values.cast[0] !== \"\") {\r\n            data['cast'] = values.cast;\r\n        }\r\n        var formData = new FormData();\r\n        if (poster && poster !== null) {\r\n            formData.append('poster', poster)               \r\n        }\r\n        if (landscape && landscape !== null) {\r\n            formData.append('landscape', landscape)            \r\n        }\r\n        formData.append('token', props.token)\r\n        axios({\r\n            method: 'POST',\r\n            url: `${api.movies}/`,\r\n            data: data,\r\n            headers: {\r\n                'Content-Type': 'application/json',\r\n                'Authorization': `Token ${props.token}`            \r\n            }\r\n        }).then(res => {                        \r\n            if (res.status === 201 || res.status === 200) {      \r\n                console.log(res)\r\n                axios({\r\n                    method: 'PUT',\r\n                    url: `${api.movies}/${res.data.id}/`,\r\n                    data: formData,\r\n                    headers: {\r\n                        'Content-Type': 'multipart/form-data',\r\n                        'Authorization': `Token ${props.token}`            \r\n                    }\r\n                }).then(res => {                        \r\n                    if (res.status === 201 || res.status === 200) {                \r\n                        message.info(\"Нэмэгдлээ.\");\r\n                        form.resetFields();\r\n                    }             \r\n                }).catch(err => {   \r\n                    message.error(\"Амжилтгүй боллоо.\"); \r\n                    console.log(err);            \r\n                })                          \r\n            }             \r\n        }).catch(err => {   \r\n            message.error(\"Амжилтгүй боллоо.\"); \r\n            console.log(err);            \r\n        })        \r\n    }\r\n\r\n    // function handleMember(arr) {\r\n    //     arr.forEach(item => \r\n\r\n    //     )\r\n    // }\r\n\r\n    function onPosterSelected (path) {        \r\n        setPoster(path);\r\n    }\r\n\r\n    function onLandscapeSelected (path) {        \r\n        setLandscape(path);\r\n    }\r\n\r\n    return (\r\n        <div>\r\n            <Form layout=\"vertical\" form={form} onFinish={onFinish}\r\n            >\r\n                <Form.Item name=\"name\" label=\"Нэр:\" rules={[{ required: true, message: 'Та киноны нэрийг оруулна уу!' }]}>\r\n                    <Input />\r\n                </Form.Item>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col xs={24} sm={24} md={12}>\r\n                        <Form.Item name=\"description\" label=\"Дэлгэрэнгүй:\">\r\n                            <TextArea rows={8} />\r\n                        </Form.Item>  \r\n                    </Col>\r\n                    <Col xs={24} sm={24} md={12}>\r\n                        <Form.Item name=\"plot\" label=\"Агуулга:\">\r\n                            <TextArea rows={8} />\r\n                        </Form.Item>  \r\n                    </Col>\r\n                </Row>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"duration\" label=\"Хугацаа:\">\r\n                            <InputNumber defaultValue={0} min={0} style={{ width: '100%' }} />\r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"releasedate\" label=\"Нээлт:\">\r\n                            <DatePicker style={{ width: '100%' }} />\r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"rating\" label=\"Насны ангилал:\">                        \r\n                            <Select\r\n                                showSearch                                \r\n                                placeholder=\"Ангилал сонгоно уу\"                                                \r\n                                optionFilterProp=\"children\"                                \r\n                            >\r\n                                { ratings ? (\r\n                                    <>\r\n                                        {ratings.map(item => {\r\n                                            return (\r\n                                                <Option key={item.id}>{item.name}</Option>\r\n                                            )\r\n                                        })}\r\n                                    </>\r\n                                ) : (\r\n                                    <></>\r\n                                )}\r\n                            </Select>                        \r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"genre\" label=\"Төрөл жанр:\">                        \r\n                            <Select\r\n                                showSearch\r\n                                mode=\"multiple\"\r\n                                placeholder=\"Төрөл сонгоно уу\"                                                \r\n                                optionFilterProp=\"children\"                                \r\n                            >\r\n                                { genres ? (\r\n                                    <>\r\n                                        {genres.map(item => {\r\n                                            return (\r\n                                                <Option key={item.id}>{item.name}</Option>\r\n                                            )\r\n                                        })}\r\n                                    </>\r\n                                ) : (\r\n                                    <></>\r\n                                )}\r\n                            </Select>                        \r\n                        </Form.Item>\r\n                    </Col>\r\n                </Row>\r\n                <Row gutter={16}>       \r\n                    <Col xs={24} sm={12} md={12} lg={8}>                        \r\n                        <Form.Item name=\"poster\" label=\"Постер:\">                               \r\n                            <ImageUpload onImageSelected={onPosterSelected} height=\"300px\" width=\"200px\" />                        \r\n                        </Form.Item>\r\n                    </Col>             \r\n                    <Col xs={24} sm={12} md={12} lg={16}>                        \r\n                        <Form.Item name=\"landscape\" label=\"Өргөн зураг:\">                               \r\n                            <ImageUpload onImageSelected={onLandscapeSelected} height=\"300px\" width=\"600px\" />                        \r\n                        </Form.Item>\r\n                    </Col>                                   \r\n                </Row>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col span={11} style={{ marginBottom: '8px' }}>\r\n                        <Typography.Text>Баг бүрэлдэхүүн</Typography.Text>                                \r\n                    </Col>\r\n                    <Col span={11}>\r\n                        <Typography.Text>Үүрэг</Typography.Text>\r\n                    </Col>\r\n                    <Col span={2}></Col>                    \r\n                </Row>\r\n                <Form.List name=\"crew\">                                                        \r\n                    {(fields, { add, remove }) => (\r\n                    <>\r\n                        {fields.map(field => (\r\n                        <Row key={field.key} gutter={[8, 8]} style={{ width: '100%' }}>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'artist']}\r\n                                    fieldKey={[field.fieldKey, 'artist']}                                                \r\n                                >\r\n                                    <Select \r\n                                        showSearch\r\n                                        onSearch={onArtistSearch}                                \r\n                                        placeholder=\"Уран бүтээлч\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { artists ? (\r\n                                            <>\r\n                                                {artists.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>\r\n                            </Col>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'role']}\r\n                                    fieldKey={[field.fieldKey, 'role']}                                      \r\n                                >\r\n                                    <Select \r\n                                        showSearch                                                              \r\n                                        placeholder=\"Үүрэг\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { occupations ? (\r\n                                            <>\r\n                                                {occupations.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>   \r\n                            </Col>\r\n                            <Col span={2}>\r\n                                <Form.Item>\r\n                                    <PlusCircleOutlined onClick={() => add()} style={{ marginRight: '8px', fontSize: '20px', color: '#888' }} />\r\n                                    <MinusCircleOutlined onClick={() => remove(field.name)} style={{ fontSize: '20px', color: '#888' }} />\r\n                                </Form.Item>  \r\n                            </Col>\r\n                        </Row>\r\n                        ))}                                \r\n                    </>\r\n                    )}                                                                                                            \r\n                </Form.List>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col span={11} style={{ marginBottom: '8px' }}>\r\n                        <Typography.Text>Жүжигчид</Typography.Text>                                \r\n                    </Col>\r\n                    <Col span={11}>\r\n                        <Typography.Text>Дүр</Typography.Text>\r\n                    </Col>\r\n                    <Col span={2}></Col>                    \r\n                </Row>\r\n                <Form.List name=\"cast\">                                                        \r\n                    {(fields, { add, remove }) => (\r\n                    <>\r\n                        {fields.map(field => (\r\n                        <Row key={field.key} gutter={[8, 8]} style={{ width: '100%' }}>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'artist']}\r\n                                    fieldKey={[field.fieldKey, 'artist']}                                                 \r\n                                >\r\n                                    <Select \r\n                                        showSearch\r\n                                        onSearch={onArtistSearch}                                \r\n                                        placeholder=\"Уран бүтээлч\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { artists ? (\r\n                                            <>\r\n                                                {artists.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>\r\n                            </Col>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'role_name']}\r\n                                    fieldKey={[field.fieldKey, 'role_name']}                                      \r\n                                >\r\n                                    <Input placeholder=\"Дүр\" /> \r\n                                </Form.Item>   \r\n                            </Col>\r\n                            <Col span={2}>\r\n                                <Form.Item>\r\n                                    <PlusCircleOutlined onClick={() => add()} style={{ marginRight: '8px', fontSize: '20px', color: '#888' }} />\r\n                                    <MinusCircleOutlined onClick={() => remove(field.name)} style={{ fontSize: '20px', color: '#888' }} />\r\n                                </Form.Item>  \r\n                            </Col>\r\n                        </Row>\r\n                        ))}                                \r\n                    </>\r\n                    )}                                                                                                            \r\n                </Form.List>               \r\n                <Form.Item>\r\n                    <div style={{ display: 'flex', justifyContent: 'flex-start' }}>\r\n                        <Popconfirm title=\"Нэмэх үү？\" okText=\"Тийм\" cancelText=\"Үгүй\" onConfirm={form.submit}>\r\n                            <Button type=\"primary\" icon={<PlusOutlined />}>\r\n                                Нэмэх\r\n                            </Button>\r\n                        </Popconfirm>\r\n                    </div>                                        \r\n                </Form.Item>                                       \r\n            </Form>\r\n        </div>\r\n    )\r\n}\r\n\r\nconst mapStateToProps = state => {\r\n    return {\r\n        token: state.token\r\n    }\r\n}\r\n\r\nexport default connect(mapStateToProps)(MovieAdd);","C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistAdd.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Moderator.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\GenreTag.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieAdd.js",["327"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\artist\\ArtistAdd.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\artist\\ArtistUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieUpdate.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\artist\\ArtistList.js",["328"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\artist\\ArtistCard.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistList.js",["329"],"import { Grid, Breadcrumb, Col, List, Pagination, Row, Input, Select, Form } from 'antd';\r\nimport React, { useState, useEffect } from 'react';\r\nimport axios from 'axios';  \r\nimport api from '../api';\r\nimport ArtistCard from './ArtistCard';\r\n\r\nconst { useBreakpoint } = Grid;\r\nconst { Option } = Select;\r\nconst { Search } = Input;\r\n\r\nfunction ArtistList () {\r\n    const screens = useBreakpoint();\r\n    const [form] = Form.useForm();\r\n    const [artists, setArtists] = useState();    \r\n    const [page, setPage] = useState(1);\r\n    const [total, setTotal] = useState();\r\n    const [name, setName] = useState();\r\n    const [occupations, setOccupations] = useState();     \r\n    const [occupation, setOccupation] = useState();    \r\n    const [order, setOrder] = useState();   \r\n\r\n    useEffect(() => {\r\n        if (!occupations) {\r\n            axios({\r\n                method: 'GET',\r\n                url: api.occupations\r\n            })\r\n            .then(res => {                        \r\n                setOccupations(res.data.results);            \r\n            })        \r\n            .catch(err => {\r\n                console.log(err.message);\r\n            }) \r\n        }; \r\n        getArtists(name, occupation, page, order)\r\n    }, [name, occupation, page, order])\r\n\r\n    function getArtists(name, occupation, page, order) {\r\n        var url = api.artists + \"?\"\r\n        var params = []\r\n        if (name && name.length > 0) {\r\n            params.push(\"name=\" + name)\r\n        }\r\n        if (occupation && occupation > 0) {\r\n            params.push(\"occupation=\" + occupation)\r\n        }\r\n        if (order) {\r\n            params.push(\"order=\" + order)\r\n        }\r\n        params.forEach(param => {\r\n            url += param + \"&\"\r\n        })        \r\n        url += \"page=\" + page                \r\n        axios({\r\n            method: 'GET',\r\n            url: url\r\n        }).then(res => {                    \r\n            console.log(res.data)                \r\n            setArtists(res.data.results)\r\n            setTotal(res.data.count)\r\n        }).catch(err => {\r\n            console.log(err.message)\r\n        });        \r\n    }\r\n\r\n    function onNameSearch(value) {        \r\n        setName(value);\r\n    }\r\n\r\n    function selectOccupation (value) {        \r\n        setOccupation(value);\r\n    }\r\n\r\n    function selectOrder (value) {\r\n        setOrder(value);\r\n    }\r\n\r\n    function onPageChange (pageNum, pageSize) {        \r\n        setPage(pageNum)\r\n    }\r\n\r\n    function showTotal(total) {\r\n        return `Нийт ${total} кино:`;\r\n    }\r\n\r\n    function getPadding() {\r\n        if (screens.xxl) {\r\n            return '24px 15% 0 15%';\r\n        } else if (screens.xl) {\r\n            return '24px 15% 0 15%';\r\n        } else if ( screens.lg) {\r\n            return '24px 15% 0 15%';\r\n        } else if (screens.md) {\r\n            return '16px 5% 0 5%';\r\n        } else if (screens.sm) {\r\n            return '16px 5% 0 5%';\r\n        } else if (screens.xs) {\r\n            return '16px 5% 0 5%';\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div style={{ marginTop: '80px', minHeight: '80vh' }}>\r\n            <div style={{ padding: getPadding() }}>\r\n                <Breadcrumb>\r\n                    <Breadcrumb.Item>\r\n                        <a href=\"/\">Нүүр</a>\r\n                    </Breadcrumb.Item>\r\n                    <Breadcrumb.Item>\r\n                        Уран бүтээлч\r\n                    </Breadcrumb.Item>\r\n                </Breadcrumb>\r\n            </div>\r\n            <div style={{ padding: getPadding() }}>\r\n                <Form form={form} layout=\"vertical\">\r\n                    <Row gutter={[16, 16]}>\r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"name\" label=\"Уран бүтээлч хайх:\">                            \r\n                                <Search placeholder=\"Уран бүтээлчийн нэрээр хайх\" onSearch={onNameSearch} enterButton />\r\n                            </Form.Item>\r\n                        </Col>\r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"occupation\" label=\"Мэргэжил сонгох\">                                \r\n                                <Select                                                                                      \r\n                                    showSearch                            \r\n                                    style={{ width: '100%' }}\r\n                                    placeholder=\"Бүгд\"                \r\n                                    onChange={selectOccupation}\r\n                                    optionFilterProp=\"children\"                                                 \r\n                                >\r\n                                    <Option key=\"all\">Бүгд</Option>\r\n                                    { occupations ? (\r\n                                        <>\r\n                                            {occupations.map(item => {\r\n                                                return (\r\n                                                    <Option key={item.id}>{item.name}</Option>\r\n                                                )\r\n                                            })}\r\n                                        </>\r\n                                    ) : (\r\n                                        <></>\r\n                                    )}\r\n                                </Select>\r\n                            </Form.Item>                                                    \r\n                        </Col>                                                           \r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"order\" label=\"Эрэмбэлэх:\">                                \r\n                                <Select                                \r\n                                    showSearch                            \r\n                                    style={{ width: '100%' }}\r\n                                    placeholder=\"Шинээр нэмэгдсэн\"                \r\n                                    onChange={selectOrder}\r\n                                    optionFilterProp=\"children\"                \r\n                                >                                    \r\n                                    <Option key=\"created_at\">Шинээр нэмэгдсэн</Option>\r\n                                    <Option key=\"birthday\">Төрсөн өдрөөр(2021 > 1900)</Option>                                    \r\n                                    <Option key=\"views\">Хандалтаар (100 > 0)</Option>\r\n                                    <Option key=\"likes\">Like-n тоогоор (100 > 0)</Option>        \r\n                                    <Option key=\"name\">Үсгийн дарааллаар (A - Z)</Option>                                    \r\n                                </Select>\r\n                            </Form.Item>  \r\n                        </Col>\r\n                    </Row>\r\n                </Form>\r\n                <List                        \r\n                    grid={{\r\n                        gutter: 16,\r\n                        xs: 3,\r\n                        sm: 3,\r\n                        md: 4,\r\n                        lg: 6,\r\n                        xl: 6,\r\n                        xxl: 8,\r\n                    }}                                        \r\n                    style={{ marginTop: '16px' }}                \r\n                    dataSource={artists ? artists : undefined}\r\n                    renderItem={item => (\r\n                        <List.Item>\r\n                            <ArtistCard item={item} />\r\n                        </List.Item>\r\n                    )}\r\n                />\r\n                <Pagination\r\n                    current={page}\r\n                    total={total}\r\n                    pageSize={24}\r\n                    hideOnSinglePage={true}\r\n                    showSizeChanger={false}\r\n                    showTotal={showTotal}\r\n                    onChange={onPageChange}\r\n                />\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default ArtistList;","C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistCard.js",[],{"ruleId":"330","replacedBy":"331"},{"ruleId":"332","replacedBy":"333"},{"ruleId":"330","replacedBy":"334"},{"ruleId":"332","replacedBy":"335"},{"ruleId":"336","severity":1,"message":"337","line":18,"column":8,"nodeType":"338","endLine":18,"endColumn":10,"suggestions":"339"},{"ruleId":"330","replacedBy":"340"},{"ruleId":"332","replacedBy":"341"},{"ruleId":"336","severity":1,"message":"342","line":41,"column":8,"nodeType":"338","endLine":41,"endColumn":34,"suggestions":"343"},{"ruleId":"336","severity":1,"message":"342","line":41,"column":8,"nodeType":"338","endLine":41,"endColumn":34,"suggestions":"344"},{"ruleId":"345","severity":1,"message":"346","line":5,"column":66,"nodeType":"347","messageId":"348","endLine":5,"endColumn":81},{"ruleId":"336","severity":1,"message":"337","line":25,"column":8,"nodeType":"338","endLine":25,"endColumn":10,"suggestions":"349"},{"ruleId":"345","severity":1,"message":"350","line":172,"column":14,"nodeType":"347","messageId":"348","endLine":172,"endColumn":19},{"ruleId":"345","severity":1,"message":"351","line":203,"column":11,"nodeType":"347","messageId":"348","endLine":203,"endColumn":19},{"ruleId":"345","severity":1,"message":"352","line":207,"column":11,"nodeType":"347","messageId":"348","endLine":207,"endColumn":19},{"ruleId":"336","severity":1,"message":"353","line":57,"column":8,"nodeType":"338","endLine":57,"endColumn":10,"suggestions":"354"},{"ruleId":"336","severity":1,"message":"353","line":57,"colu