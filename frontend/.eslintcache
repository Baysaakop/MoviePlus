\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\routes.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\utility.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\actions\\actionTypes.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\layout\\Layout.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\PasswordResetConfirm.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Login.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Signup.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Logout.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Profile.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\PasswordReset.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemList.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemDetail.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\item\\ItemCreate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\posts\\PostCreate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\containers\\Home.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\icons\\MoonIcon.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\icons\\SunIcon.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\Menu.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\api.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\actions\\auth.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\AccountDetail.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\ImageUpload.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieCard.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieList.js",["301"],"import { Grid, Breadcrumb, Col, List, Pagination, Row, Input, Select, Form } from 'antd';\r\nimport React, { useState, useEffect } from 'react';\r\nimport MovieCard from './MovieCard';\r\nimport axios from 'axios';  \r\nimport api from '../api';\r\n\r\nconst { useBreakpoint } = Grid;\r\nconst { Option } = Select;\r\nconst { Search } = Input;\r\n\r\nfunction MovieList() {\r\n    const screens = useBreakpoint();\r\n    const [form] = Form.useForm();\r\n    const [movies, setMovies] = useState();    \r\n    const [page, setPage] = useState(1);\r\n    const [total, setTotal] = useState();\r\n    const [name, setName] = useState();\r\n    const [genres, setGenres] = useState();     \r\n    const [genre, setGenre] = useState();    \r\n    const [order, setOrder] = useState();    \r\n\r\n    useEffect(() => {\r\n        if (!genres) {\r\n            axios({\r\n                method: 'GET',\r\n                url: api.genres\r\n            })\r\n            .then(res => {                        \r\n                setGenres(res.data.results);            \r\n            })        \r\n            .catch(err => {\r\n                console.log(err.message);\r\n            }) \r\n        }; \r\n        // let name = getLocationSearch(props.location.search);\r\n        // setSearch(name)\r\n        // form.setFieldsValue({            \r\n        //     name: name           \r\n        // }) \r\n       getMovies(name, genre, page, order)\r\n    }, [name, genre, page, order])   \r\n\r\n    function getMovies(name, genre, page, order) {\r\n        var url = api.movies + \"?\"\r\n        var params = []\r\n        if (name && name.length > 0) {\r\n            params.push(\"name=\" + name)\r\n        }\r\n        if (genre && genre > 0) {\r\n            params.push(\"genre=\" + genre)\r\n        }\r\n        if (order) {\r\n            params.push(\"order=\" + order)\r\n        }\r\n        params.forEach(param => {\r\n            url += param + \"&\"\r\n        })        \r\n        url += \"page=\" + page                \r\n        axios({\r\n            method: 'GET',\r\n            url: url\r\n        }).then(res => {                    \r\n            console.log(res.data)                \r\n            setMovies(res.data.results)\r\n            setTotal(res.data.count)\r\n        }).catch(err => {\r\n            console.log(err.message)\r\n        });        \r\n    }\r\n\r\n    // function getLocationSearch(value) {    \r\n    //     if (value && value !== null && value.length > 0 && value.includes(\"=\")) {\r\n    //         let res = value.split(\"=\");            \r\n    //         return res[1];\r\n    //     } else {\r\n    //         return \"\";\r\n    //     }    \r\n    // }\r\n\r\n    function onNameSearch(value) {        \r\n        setName(value);\r\n    }\r\n\r\n    function selectGenre (value) {        \r\n        setGenre(value);\r\n    }\r\n\r\n    function selectOrder (value) {\r\n        setOrder(value);\r\n    }\r\n\r\n    function onPageChange (pageNum, pageSize) {        \r\n        setPage(pageNum)\r\n    }\r\n\r\n    function showTotal(total) {\r\n        return `Нийт ${total} кино:`;\r\n    }\r\n\r\n    function getPadding() {\r\n        if (screens.xxl) {\r\n            return '24px 15% 0 15%';\r\n        } else if (screens.xl) {\r\n            return '24px 15% 0 15%';\r\n        } else if ( screens.lg) {\r\n            return '24px 15% 0 15%';\r\n        } else if (screens.md) {\r\n            return '16px 5% 0 5%';\r\n        } else if (screens.sm) {\r\n            return '16px 5% 0 5%';\r\n        } else if (screens.xs) {\r\n            return '16px 5% 0 5%';\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div style={{ marginTop: '80px', minHeight: '80vh' }}>\r\n            <div style={{ padding: getPadding() }}>\r\n                <Breadcrumb>\r\n                    <Breadcrumb.Item>\r\n                        <a href=\"/\">Нүүр</a>\r\n                    </Breadcrumb.Item>\r\n                    <Breadcrumb.Item>\r\n                        Кино\r\n                    </Breadcrumb.Item>\r\n                </Breadcrumb>\r\n            </div>\r\n            <div style={{ padding: getPadding() }}>\r\n                <Form form={form} layout=\"vertical\" initialValues={{\r\n                    genre: \"all\",\r\n                    order: \"created_at\"\r\n                }}>\r\n                    <Row gutter={[16, 16]}>\r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"name\" label=\"Кино хайх:\">                            \r\n                                <Search placeholder=\"Киноны нэрээр хайх\" onSearch={onNameSearch} enterButton />\r\n                            </Form.Item>\r\n                        </Col>\r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"genre\" label=\"Төрөл сонгох\">                                \r\n                                <Select                      \r\n                                    // dropdownStyle={{ backgroundColor: '#161b22' }}                                \r\n                                    showSearch                            \r\n                                    style={{ width: '100%' }}\r\n                                    placeholder=\"Бүгд\"                \r\n                                    onChange={selectGenre}\r\n                                    optionFilterProp=\"children\"                                                 \r\n                                >\r\n                                    <Option key=\"all\">Бүгд</Option>\r\n                                    { genres ? (\r\n                                        <>\r\n                                            {genres.map(item => {\r\n                                                return (\r\n                                                    <Option key={item.id}>{item.name}</Option>\r\n                                                )\r\n                                            })}\r\n                                        </>\r\n                                    ) : (\r\n                                        <></>\r\n                                    )}\r\n                                </Select>\r\n                            </Form.Item>                                                    \r\n                        </Col>                                                           \r\n                        <Col sm={24} md={8}>\r\n                            <Form.Item name=\"order\" label=\"Эрэмбэлэх:\">                                \r\n                                <Select                                \r\n                                    showSearch                            \r\n                                    style={{ width: '100%' }}\r\n                                    placeholder=\"Шинээр нэмэгдсэн\"                \r\n                                    onChange={selectOrder}\r\n                                    optionFilterProp=\"children\"                \r\n                                >                                    \r\n                                    <Option key=\"created_at\">Шинээр нэмэгдсэн</Option>\r\n                                    <Option key=\"releasedate\">Нээлтийн огноогоор(2021 - 1900)</Option>\r\n                                    <Option key=\"score\">Үнэлгээгээр(100 - 0)</Option>\r\n                                    <Option key=\"views\">Хандалтаар (100 - 0)</Option>\r\n                                    <Option key=\"likes\">Like-n тоогоор (100 - 0)</Option>        \r\n                                    <Option key=\"name\">Үсгийн дарааллаар (A - Z)</Option>                                    \r\n                                </Select>\r\n                            </Form.Item>  \r\n                        </Col>\r\n                    </Row>\r\n                </Form>\r\n                <List                        \r\n                    grid={{\r\n                        gutter: 16,\r\n                        xs: 2,\r\n                        sm: 2,\r\n                        md: 3,\r\n                        lg: 4,\r\n                        xl: 5,\r\n                        xxl: 6,\r\n                    }}                                        \r\n                    style={{ marginTop: '16px' }}                \r\n                    dataSource={movies ? movies : undefined}\r\n                    renderItem={item => (\r\n                        <List.Item>\r\n                            <MovieCard item={item} />\r\n                        </List.Item>\r\n                    )}\r\n                />\r\n                <Pagination\r\n                    current={page}\r\n                    total={total}\r\n                    pageSize={4}\r\n                    hideOnSinglePage={true}\r\n                    showSizeChanger={false}\r\n                    showTotal={showTotal}\r\n                    onChange={onPageChange}\r\n                />\r\n            </div>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default MovieList;","C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieList.js",["302"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\components\\GenreTag.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\account\\Moderato