rs\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\api.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\store\\actions\\auth.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\AccountDetail.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\ImageUpload.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieCard.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],["359","360"],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieList.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieList.js",["361"],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieTrendTable.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieDetail.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\components\\GenreTag.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\account\\Moderator.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\movie\\MovieAdd.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistAdd.js",[],"C:\\Users\\baysa\\Documents\\github\\MoviePlus\\frontend\\src\\artist\\ArtistUpdate.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\account\\Moderator.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\components\\GenreTag.js",[],"C:\\Users\\baysa\\Documents\\GitHub\\MoviePlus\\frontend\\src\\movie\\MovieAdd.js",["362"],"import { MinusCircleOutlined, PlusCircleOutlined, PlusOutlined } from '@ant-design/icons';\r\nimport { Typography, Form, Row, Col, Input, InputNumber, Select, Button, Popconfirm, DatePicker, message } from 'antd';\r\nimport React, { useState, useEffect } from 'react';\r\nimport ImageUpload from '../components/ImageUpload';\r\nimport axios from 'axios';\r\nimport api from '../api';\r\nimport { connect } from \"react-redux\";\r\nimport moment from 'moment';\r\n\r\nconst { TextArea } = Input;\r\nconst { Option } = Select;\r\n\r\nfunction MovieAdd (props) {\r\n    const [form] = Form.useForm();    \r\n    const [poster, setPoster] = useState();\r\n    const [landscape, setLandscape] = useState();\r\n    const [ratings, setRatings] = useState(); \r\n    const [genres, setGenres] = useState(); \r\n    const [occupations, setOccupations] = useState(); \r\n    const [artists, setArtists] = useState(); \r\n\r\n    useEffect(() => {\r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.ratings\r\n        })\r\n        .then(res => {                        \r\n            setRatings(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.genres\r\n        })\r\n        .then(res => {                        \r\n            setGenres(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.occupations\r\n        })\r\n        .then(res => {                        \r\n            setOccupations(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        }) \r\n        form.setFieldsValue({\r\n            crew: [''],\r\n            cast: ['']\r\n        })\r\n    }, [])\r\n\r\n    function onArtistSearch(value) {                \r\n        axios({\r\n            method: 'GET',                        \r\n            url: api.artists + \"?name=\" + value\r\n        })\r\n        .then(res => {                        \r\n            setArtists(res.data.results);            \r\n        })        \r\n        .catch(err => {\r\n            console.log(err.message);\r\n        })      \r\n    }\r\n\r\n    function onFinish (values) {      \r\n        console.log(values)            \r\n        const data = {\r\n            name: values.name,\r\n            token: props.token\r\n        }\r\n        if (values.description && values.description !== null) {\r\n            data['description'] = values.description;\r\n        }\r\n        if (values.plot && values.plot !== null) {\r\n            data['plot'] = values.plot;\r\n        }\r\n        if (values.releasedate && values.releasedate !== null) {            \r\n            data['releasedate'] = moment(values.releasedate).format(\"YYYY-MM-DD\");\r\n        }\r\n        if (values.duration && values.duration !== null) {            \r\n            data['duration'] = values.duration;\r\n        }\r\n        if (values.rating && values.rating !== null) {            \r\n            data['rating'] = values.rating;\r\n        }\r\n        if (values.genre && values.genre !== null && values.genre.length > 0 && values.genre[0] !== \"\") {\r\n            data['genre'] = values.genre;\r\n        }\r\n        if (values.crew && values.crew !== null && values.crew.length > 0 && values.crew[0] !== \"\") {\r\n            data['crew'] = values.crew;\r\n        }\r\n        if (values.cast && values.cast !== null && values.cast.length > 0 && values.cast[0] !== \"\") {\r\n            data['cast'] = values.cast;\r\n        }\r\n        var formData = new FormData();\r\n        if (poster && poster !== null) {\r\n            formData.append('poster', poster)               \r\n        }\r\n        if (landscape && landscape !== null) {\r\n            formData.append('landscape', landscape)            \r\n        }\r\n        formData.append('token', props.token)\r\n        axios({\r\n            method: 'POST',\r\n            url: `${api.movies}/`,\r\n            data: data,\r\n            headers: {\r\n                'Content-Type': 'application/json',\r\n                'Authorization': `Token ${props.token}`            \r\n            }\r\n        }).then(res => {                        \r\n            if (res.status === 201 || res.status === 200) {      \r\n                console.log(res)\r\n                axios({\r\n                    method: 'PUT',\r\n                    url: `${api.movies}/${res.data.id}/`,\r\n                    data: formData,\r\n                    headers: {\r\n                        'Content-Type': 'multipart/form-data',\r\n                        'Authorization': `Token ${props.token}`            \r\n                    }\r\n                }).then(res => {                        \r\n                    if (res.status === 201 || res.status === 200) {                \r\n                        message.info(\"Нэмэгдлээ.\");\r\n                        form.resetFields();\r\n                    }             \r\n                }).catch(err => {   \r\n                    message.error(\"Амжилтгүй боллоо.\"); \r\n                    console.log(err);            \r\n                })                          \r\n            }             \r\n        }).catch(err => {   \r\n            message.error(\"Амжилтгүй боллоо.\"); \r\n            console.log(err);            \r\n        })        \r\n    }\r\n\r\n    // function handleMember(arr) {\r\n    //     arr.forEach(item => \r\n\r\n    //     )\r\n    // }\r\n\r\n    function onPosterSelected (path) {        \r\n        setPoster(path);\r\n    }\r\n\r\n    function onLandscapeSelected (path) {        \r\n        setLandscape(path);\r\n    }\r\n\r\n    return (\r\n        <div>\r\n            <Form layout=\"vertical\" form={form} onFinish={onFinish}\r\n            >\r\n                <Form.Item name=\"name\" label=\"Нэр:\" rules={[{ required: true, message: 'Та киноны нэрийг оруулна уу!' }]}>\r\n                    <Input />\r\n                </Form.Item>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col xs={24} sm={24} md={12}>\r\n                        <Form.Item name=\"description\" label=\"Дэлгэрэнгүй:\">\r\n                            <TextArea rows={8} />\r\n                        </Form.Item>  \r\n                    </Col>\r\n                    <Col xs={24} sm={24} md={12}>\r\n                        <Form.Item name=\"plot\" label=\"Агуулга:\">\r\n                            <TextArea rows={8} />\r\n                        </Form.Item>  \r\n                    </Col>\r\n                </Row>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"duration\" label=\"Хугацаа:\">\r\n                            <InputNumber defaultValue={0} min={0} style={{ width: '100%' }} />\r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"releasedate\" label=\"Нээлт:\">\r\n                            <DatePicker style={{ width: '100%' }} />\r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"rating\" label=\"Насны ангилал:\">                        \r\n                            <Select\r\n                                showSearch                                \r\n                                placeholder=\"Ангилал сонгоно уу\"                                                \r\n                                optionFilterProp=\"children\"                                \r\n                            >\r\n                                { ratings ? (\r\n                                    <>\r\n                                        {ratings.map(item => {\r\n                                            return (\r\n                                                <Option key={item.id}>{item.name}</Option>\r\n                                            )\r\n                                        })}\r\n                                    </>\r\n                                ) : (\r\n                                    <></>\r\n                                )}\r\n                            </Select>                        \r\n                        </Form.Item>\r\n                    </Col>\r\n                    <Col xs={12} sm={8} md={6}>\r\n                        <Form.Item name=\"genre\" label=\"Төрөл жанр:\">                        \r\n                            <Select\r\n                                showSearch\r\n                                mode=\"multiple\"\r\n                                placeholder=\"Төрөл сонгоно уу\"                                                \r\n                                optionFilterProp=\"children\"                                \r\n                            >\r\n                                { genres ? (\r\n                                    <>\r\n                                        {genres.map(item => {\r\n                                            return (\r\n                                                <Option key={item.id}>{item.name}</Option>\r\n                                            )\r\n                                        })}\r\n                                    </>\r\n                                ) : (\r\n                                    <></>\r\n                                )}\r\n                            </Select>                        \r\n                        </Form.Item>\r\n                    </Col>\r\n                </Row>\r\n                <Row gutter={16}>       \r\n                    <Col xs={24} sm={12} md={12} lg={8}>                        \r\n                        <Form.Item name=\"poster\" label=\"Постер:\">                               \r\n                            <ImageUpload onImageSelected={onPosterSelected} height=\"300px\" width=\"200px\" />                        \r\n                        </Form.Item>\r\n                    </Col>             \r\n                    <Col xs={24} sm={12} md={12} lg={16}>                        \r\n                        <Form.Item name=\"landscape\" label=\"Өргөн зураг:\">                               \r\n                            <ImageUpload onImageSelected={onLandscapeSelected} height=\"300px\" width=\"600px\" />                        \r\n                        </Form.Item>\r\n                    </Col>                                   \r\n                </Row>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col span={11} style={{ marginBottom: '8px' }}>\r\n                        <Typography.Text>Баг бүрэлдэхүүн</Typography.Text>                                \r\n                    </Col>\r\n                    <Col span={11}>\r\n                        <Typography.Text>Үүрэг</Typography.Text>\r\n                    </Col>\r\n                    <Col span={2}></Col>                    \r\n                </Row>\r\n                <Form.List name=\"crew\">                                                        \r\n                    {(fields, { add, remove }) => (\r\n                    <>\r\n                        {fields.map(field => (\r\n                        <Row key={field.key} gutter={[8, 8]} style={{ width: '100%' }}>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'artist']}\r\n                                    fieldKey={[field.fieldKey, 'artist']}                                                \r\n                                >\r\n                                    <Select \r\n                                        showSearch\r\n                                        onSearch={onArtistSearch}                                \r\n                                        placeholder=\"Уран бүтээлч\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { artists ? (\r\n                                            <>\r\n                                                {artists.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>\r\n                            </Col>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'role']}\r\n                                    fieldKey={[field.fieldKey, 'role']}                                      \r\n                                >\r\n                                    <Select \r\n                                        showSearch                                                              \r\n                                        placeholder=\"Үүрэг\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { occupations ? (\r\n                                            <>\r\n                                                {occupations.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>   \r\n                            </Col>\r\n                            <Col span={2}>\r\n                                <Form.Item>\r\n                                    <PlusCircleOutlined onClick={() => add()} style={{ marginRight: '8px', fontSize: '20px', color: '#888' }} />\r\n                                    <MinusCircleOutlined onClick={() => remove(field.name)} style={{ fontSize: '20px', color: '#888' }} />\r\n                                </Form.Item>  \r\n                            </Col>\r\n                        </Row>\r\n                        ))}                                \r\n                    </>\r\n                    )}                                                                                                            \r\n                </Form.List>\r\n                <Row gutter={[16, 16]}>\r\n                    <Col span={11} style={{ marginBottom: '8px' }}>\r\n                        <Typography.Text>Жүжигчид</Typography.Text>                                \r\n                    </Col>\r\n                    <Col span={11}>\r\n                        <Typography.Text>Дүр</Typography.Text>\r\n                    </Col>\r\n                    <Col span={2}></Col>                    \r\n                </Row>\r\n                <Form.List name=\"cast\">                                                        \r\n                    {(fields, { add, remove }) => (\r\n                    <>\r\n                        {fields.map(field => (\r\n                        <Row key={field.key} gutter={[8, 8]} style={{ width: '100%' }}>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'artist']}\r\n                                    fieldKey={[field.fieldKey, 'artist']}                                                 \r\n                                >\r\n                                    <Select \r\n                                        showSearch\r\n                                        onSearch={onArtistSearch}                                \r\n                                        placeholder=\"Уран бүтээлч\"                                                \r\n                                        optionFilterProp=\"children\"                                                             \r\n                                    >\r\n                                        { artists ? (\r\n                                            <>\r\n                                                {artists.map(item => {\r\n                                                    return (\r\n                                                        <Option key={item.id}>{item.name}</Option>\r\n                                                    )\r\n                                                })}\r\n                                            </>\r\n                                        ) : (\r\n                                            <></>\r\n                                        )}\r\n                                    </Select> \r\n                                </Form.Item>\r\n                            </Col>\r\n                            <Col span={11}>\r\n                                <Form.Item\r\n                                {...field}\r\n                                    name={[field.name, 'role_name']}\r\n                                    fieldKey={[field.fieldKey, 'role_name']}                                      \r\n                                >\r\n                                    <Input placeholder=\"Дүр\" /> \r\n                                </Form.Item>   \r\n                            </Col>\r\n                            <Col span={2}>\r\n                                <Form.Item>\r\n                                    <PlusCircleOutlined onClick={() => add()} style={{ marginRight: '8px', fontSize: '20px', color: '#888' }} />\r\n                                    <MinusCircleOutlined onClick={() => remove(field.name)} style={{ fontSize: '20px', color: '#888' }} />\r\n                                </Form.Item>  \r\n                            </Col>\r\n                        </Row>\r\n                        ))}                                \r\n                    </>\r\n                    )}                                                                                                            \r\n                </Form.List>               \r\n                <Form.Item>\r\n                    <div style={{ display: 'flex', justifyContent: 'flex-start' }}>\r\n                        <Popconfirm title=\"Нэмэх үү？\" okText=\"Тийм\" cancelText=\"Үгүй\" onConfirm={form.submit}>\r\n                            <Button type=\"primary\" icon={<PlusOutlined />}>\r\n                                Нэмэх\r\n                            </Button>\r\n                        </Popconfirm>\r\n                    </div>                                        \r\n                </Form.Item>                                       \r\n            </Form>\r\n        </div>\r\n    )\r\n}\r\n\r\nconst mapStateToProps = state => {\r\n    return {\r\n        token: state.token\r\n    }\r\n}\r\n\r\nexport de